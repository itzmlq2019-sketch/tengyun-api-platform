<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tengyunapibackend.mapper.InterfaceInfoMapper">

    <resultMap id="BaseResultMap" type="com.example.tengyunapicommon.entity.InterfaceInfo">
            <id property="id" column="id" />
            <result property="name" column="name" />
            <result property="description" column="description" />
            <result property="url" column="url" />
            <result property="requestParams" column="request_params" />
            <result property="requestHeader" column="request_header" />
            <result property="responseHeader" column="response_header" />
            <result property="status" column="status" />
            <result property="method" column="method" />
            <result property="userId" column="user_id" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
            <result property="isDelete" column="is_delete" />
    </resultMap>

    <sql id="Base_Column_List">
        id,name,description,url,request_params,request_header,
        response_header,status,method,user_id,create_time,
        update_time,is_delete
    </sql>

    <resultMap id="AdminInterfaceResultMap" type="com.example.tengyunapibackend.model.vo.InterfaceAdminVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="url" column="url"/>
        <result property="method" column="method"/>
        <result property="status" column="status"/>
        <result property="userId" column="user_id"/>
        <result property="boundUserCount" column="bound_user_count"/>
        <result property="totalLeftNum" column="total_left_num"/>
        <result property="totalInvokeNum" column="total_invoke_num"/>
        <result property="successInvokeCount" column="success_invoke_count"/>
        <result property="failedInvokeCount" column="failed_invoke_count"/>
        <result property="lastInvokeTime" column="last_invoke_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="AdminInterfaceWhere">
        where i.is_delete = 0
        <if test="method != null and method != ''">
            and i.method = #{method}
        </if>
        <if test="status != null">
            and i.status = #{status}
        </if>
        <if test="name != null and name != ''">
            and i.name like concat('%', #{name}, '%')
        </if>
    </sql>

    <select id="countAdminInterfaces" resultType="java.lang.Long">
        select count(1)
        from interface_info i
        <include refid="AdminInterfaceWhere"/>
    </select>

    <select id="listAdminInterfaces" resultMap="AdminInterfaceResultMap">
        select
            i.id,
            i.name,
            i.description,
            i.url,
            i.method,
            i.status,
            <choose>
                <when test="includeSensitiveFields">
                    i.user_id as user_id,
                </when>
                <otherwise>
                    null as user_id,
                </otherwise>
            </choose>
            coalesce(uqs.bound_user_count, 0) as bound_user_count,
            coalesce(uqs.total_left_num, 0) as total_left_num,
            greatest(
                coalesce(uqs.total_invoke_num, 0),
                coalesce(ils.success_invoke_count, 0) + coalesce(ils.failed_invoke_count, 0)
            ) as total_invoke_num,
            coalesce(ils.success_invoke_count, 0) as success_invoke_count,
            coalesce(ils.failed_invoke_count, 0) as failed_invoke_count,
            ils.last_invoke_time,
            i.create_time,
            i.update_time
        from interface_info i
        left join (
            select
                ui.interface_info_id,
                count(1) as bound_user_count,
                coalesce(sum(ui.left_num), 0) as total_left_num,
                coalesce(sum(ui.total_num), 0) as total_invoke_num
            from user_interface_info ui
            where ui.is_delete = 0
            group by ui.interface_info_id
        ) uqs on i.id = uqs.interface_info_id
        left join (
            select
                il.interface_info_id,
                sum(case when il.status = 0 then 1 else 0 end) as success_invoke_count,
                sum(case when il.status = 1 then 1 else 0 end) as failed_invoke_count,
                max(il.create_time) as last_invoke_time
            from interface_invoke_log il
            where il.is_delete = 0
            group by il.interface_info_id
        ) ils on i.id = ils.interface_info_id
        <include refid="AdminInterfaceWhere"/>
        order by i.id desc
        <if test="offset != null and pageSize != null">
            limit #{offset}, #{pageSize}
        </if>
    </select>
</mapper>
