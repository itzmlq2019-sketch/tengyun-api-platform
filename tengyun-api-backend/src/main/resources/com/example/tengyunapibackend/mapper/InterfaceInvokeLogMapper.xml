<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.tengyunapibackend.mapper.InterfaceInvokeLogMapper">

    <resultMap id="BaseResultMap" type="com.example.tengyunapicommon.entity.InterfaceInvokeLog">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="interfaceInfoId" column="interface_info_id" />
        <result property="requestPath" column="request_path" />
        <result property="requestMethod" column="request_method" />
        <result property="requestParams" column="request_params" />
        <result property="responseStatus" column="response_status" />
        <result property="responseMessage" column="response_message" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="isDelete" column="is_delete" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,interface_info_id,request_path,request_method,request_params,
        response_status,response_message,status,create_time,update_time,is_delete
    </sql>

    <resultMap id="InvokeStatsResultMap" type="com.example.tengyunapibackend.model.vo.InterfaceInvokeStatsVO">
        <result property="interfaceInfoId" column="interface_info_id" />
        <result property="interfaceName" column="interface_name" />
        <result property="totalInvokeCount" column="total_invoke_count" />
        <result property="successInvokeCount" column="success_invoke_count" />
        <result property="failedInvokeCount" column="failed_invoke_count" />
        <result property="lastInvokeTime" column="last_invoke_time" />
    </resultMap>

    <select id="listInvokeStats" resultMap="InvokeStatsResultMap">
        select
            l.interface_info_id,
            max(i.name) as interface_name,
            count(1) as total_invoke_count,
            sum(case when l.status = 0 then 1 else 0 end) as success_invoke_count,
            sum(case when l.status = 1 then 1 else 0 end) as failed_invoke_count,
            max(l.create_time) as last_invoke_time
        from interface_invoke_log l
        left join interface_info i on l.interface_info_id = i.id
        where l.is_delete = 0
        <if test="userId != null">
            and l.user_id = #{userId}
        </if>
        group by l.interface_info_id
        order by total_invoke_count desc, last_invoke_time desc
        limit #{limit}
    </select>

    <select id="countInvokeLogsByStatus" resultType="java.lang.Long">
        select count(1)
        from interface_invoke_log
        where is_delete = 0
          and status = #{status}
        <if test="userId != null">
            and user_id = #{userId}
        </if>
    </select>

    <select id="listInvokeStatsByInterfaceIds" resultMap="InvokeStatsResultMap">
        select
            l.interface_info_id,
            max(i.name) as interface_name,
            count(1) as total_invoke_count,
            sum(case when l.status = 0 then 1 else 0 end) as success_invoke_count,
            sum(case when l.status = 1 then 1 else 0 end) as failed_invoke_count,
            max(l.create_time) as last_invoke_time
        from interface_invoke_log l
        left join interface_info i on l.interface_info_id = i.id
        where l.is_delete = 0
          and l.interface_info_id in
        <foreach collection="interfaceInfoIds" item="interfaceInfoId" open="(" separator="," close=")">
            #{interfaceInfoId}
        </foreach>
        group by l.interface_info_id
    </select>

    <resultMap id="UserInvokeStatsResultMap" type="com.example.tengyunapibackend.model.vo.UserInvokeStatsVO">
        <result property="userId" column="user_id" />
        <result property="successInvokeCount" column="success_invoke_count" />
        <result property="failedInvokeCount" column="failed_invoke_count" />
        <result property="lastInvokeTime" column="last_invoke_time" />
    </resultMap>

    <select id="listInvokeStatsByUserIds" resultMap="UserInvokeStatsResultMap">
        select
            user_id,
            sum(case when status = 0 then 1 else 0 end) as success_invoke_count,
            sum(case when status = 1 then 1 else 0 end) as failed_invoke_count,
            max(create_time) as last_invoke_time
        from interface_invoke_log
        where is_delete = 0
          and user_id in
        <foreach collection="userIds" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
        group by user_id
    </select>
</mapper>
